if theme.aside.card_tools && theme.aside.card_tools.enable
  .card-widget.card-tools
    .item-headline
      i.fas.fa-screwdriver-wrench
      span= theme.aside.card_tools.title || 'Tools'
    if theme.aside.card_tools.items && theme.aside.card_tools.items.length
      .tool-grid
        each item in theme.aside.card_tools.items
          a.tool-grid-item(href=item.link target="_blank" rel="noopener noreferrer" title=item.name)
            .tool-grid-icon-wrap
              if item.icon
                img.tool-grid-icon(src=url_for(item.icon) alt=item.name)
            .tool-grid-name= item.name
